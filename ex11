package com.example.ex11kav;

import android.annotation.SuppressLint;
import android.content.Intent;
import android.os.Bundle;
import android.util.Log;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.Toast;

import androidx.activity.EdgeToEdge;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.graphics.Insets;
import androidx.core.view.ViewCompat;
import androidx.core.view.WindowInsetsCompat;

import com.example.ex11kav.R;

public class MainActivity extends AppCompatActivity {
    EditText e1;
    EditText e2;
    EditText e3;
    Button b1;



    @SuppressLint("MissingInflatedId")
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        EdgeToEdge.enable(this);
        setContentView(R.layout.activity_main);
        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {
            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());
            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);
            return insets;
        });
        e1=(EditText) findViewById(R.id.editTextText);
        e2=(EditText) findViewById(R.id.editTextText2);
        e3=(EditText) findViewById(R.id.editTextText3);
        b1=(Button) findViewById(R.id.button);
        b1.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                String id = e1.getText().toString();
                String sub = e2.getText().toString();
                String content = e3.getText().toString();
                Log.i("Sending Mail", "");
                Intent i = new Intent(Intent.ACTION_SEND);
                i.setType("text/plain");
                i.putExtra(i.EXTRA_EMAIL, new String[]{id});
                i.putExtra(i.EXTRA_SUBJECT, sub);
                i.putExtra(i.EXTRA_TEXT, content);
                try {
                    startActivity(Intent.createChooser(i, "send mail"));
                    finish();
                    Log.i("Finish sending mail", "");
                } catch (android.content.ActivityNotFoundException e) {
                    Toast.makeText(MainActivity.this, "Email client is not selected", Toast.LENGTH_LONG).show();
                }
                id = e1.getText().toString();
                sub = e2.getText().toString();
                content = e3.getText().toString();
                Log.i("Sending Mail", "");
                i = new Intent(Intent.ACTION_SEND);
                i.setType("text/plain");
                i.putExtra(i.EXTRA_EMAIL, new String[]{id});
                i.putExtra(i.EXTRA_SUBJECT, sub);
                i.putExtra(i.EXTRA_TEXT, content);
                try {
                    startActivity(Intent.createChooser(i, "send mail"));
                    finish();
                    Log.i("Finish sending mail", "");
                } catch (android.content.ActivityNotFoundException e) {
                    Toast.makeText(MainActivity.this, "Email client is not selected", Toast.LENGTH_LONG).show();

                }


            }
        } );}
}
